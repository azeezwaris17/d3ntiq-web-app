{
  "name": "dentiq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "next lint --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test tests/e2e",
    "test:e2e:ui": "playwright test tests/e2e --ui",
    "test:accessibility": "playwright test tests/accessibility",
    "test:accessibility:ui": "playwright test tests/accessibility --ui",
    "test:visual": "playwright test tests/visual-regression",
    "test:visual:update": "playwright test tests/visual-regression --update-snapshots",
    "test:visual:ui": "playwright test tests/visual-regression --ui",
    "test:all": "npm run test && npm run test:e2e && npm run test:accessibility && npm run test:visual",
    "format": "prettier \"src/**/*.{ts,tsx,js,jsx,json,md}\" --write",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "validate": "npm run type-check && npm run lint && npm run format:check",
    "prepare": "husky install || true",
    "pre-commit": "lint-staged",
    "generate:model": "tsx scripts/generate-dental-model.ts",
    "generate:model:simple": "tsx scripts/generate-dental-model-simple.ts"
  },
  "dependencies": {
    "@apollo/client": "^4.1.2",
    "@emotion/react": "^11.13.3",
    "@emotion/server": "^11.11.0",
    "@fontsource/inter": "^5.2.8",
    "@hookform/resolvers": "^3.9.0",
    "@mantine/core": "^7.14.0",
    "@mantine/form": "^7.14.0",
    "@mantine/hooks": "^7.14.0",
    "@mantine/notifications": "^7.14.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@tabler/icons-react": "^3.22.0",
    "@tanstack/react-query": "^5.62.0",
    "@types/geojson": "^7946.0.16",
    "core-js": "^3.48.0",
    "eventemitter3": "^5.0.1",
    "fast-xml-parser": "^5.3.5",
    "graphql": "^16.12.0",
    "jspdf": "^4.0.0",
    "lucide-react": "^0.562.0",
    "maplibre-gl": "^5.18.0",
    "next": "^16.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-map-gl": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "three": "^0.169.0",
    "three-mesh-bvh": "^0.9.4",
    "tsyringe": "^4.8.0",
    "web-vitals": "^5.1.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@faker-js/faker": "^9.0.1",
    "@next/bundle-analyzer": "^15.5.9",
    "@playwright/test": "^1.48.2",
    "@storybook/addon-essentials": "^8.6.15",
    "@storybook/addon-interactions": "^8.6.15",
    "@storybook/react": "^8.6.15",
    "@storybook/test": "^8.6.15",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.0",
    "glob": "^11.0.0",
    "husky": "^9.1.5",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.47",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.0"
  }
}
